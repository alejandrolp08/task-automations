{
  "name": "park-ministry-listing-app",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop runner for the Park Ministry Bot - Listing.",
  "main": "app/main.js",
  "productName": "Park Ministry Listing App",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dir",
    "build:win": "electron-builder --win dir",
    "build:win:x64": "electron-builder --win dir --x64"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.parkministry.listingapp",
    "asar": false,
    "productName": "Park Ministry Listing App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "src/**/*",
      "templates/**/*",
      "docs/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "app/main.js"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/ParkMinistry.icns",
      "target": [
        "dir"
      ]
    },
    "win": {
      "icon": "assets/ParkMinistry.ico",
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "playwright": "^1.54.2"
  }
}
